<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DevToolKit</title>

<style>
:root {
  --bg: #0d1117;
  --card: #161b22;
  --text: #c9d1d9;
  --accent: #58a6ff;
}

body.light {
  --bg: #ffffff;
  --card: #f0f0f0;
  --text: #111;
}

body {
  margin: 0;
  font-family: sans-serif;
  background: var(--bg);
  color: var(--text);
}

header {
  padding: 15px;
  text-align: center;
  background: var(--card);
  font-size: 20px;
  font-weight: bold;
}

.container {
  display: flex;
  flex-direction: column;
}

.tabs {
  display: flex;
  overflow-x: auto;
  background: var(--card);
}

.tab {
  padding: 10px;
  cursor: pointer;
  flex: 1;
  text-align: center;
}

.tab.active {
  background: var(--accent);
  color: black;
}

.tool {
  display: none;
  padding: 15px;
}

.tool.active {
  display: block;
}

textarea {
  width: 100%;
  height: 150px;
  margin-top: 10px;
  background: var(--card);
  color: var(--text);
  border: none;
  padding: 10px;
}

button {
  margin-top: 10px;
  padding: 10px;
  background: var(--accent);
  border: none;
  cursor: pointer;
}

footer {
  text-align: center;
  padding: 10px;
  background: var(--card);
}
</style>
</head>

<body>

<header>
DevToolKit - Free tools for developers
</header>

<div class="tabs">
  <div class="tab active" onclick="openTool('jsx')">JSX</div>
  <div class="tab" onclick="openTool('json')">JSON</div>
  <div class="tab" onclick="openTool('base64')">Base64</div>
  <div class="tab" onclick="openTool('format')">Formatter</div>
</div>

<div class="container">

<!-- JSX TOOL -->
<div id="jsx" class="tool active">
<h3>JSX to React Converter</h3>
<textarea id="jsxInput" placeholder="Paste JSX here"></textarea>
<button onclick="convertJSX()">Convert</button>
<button onclick="copyOutput('jsxOutput')">Copy</button>
<button onclick="clearFields('jsxInput','jsxOutput')">Clear</button>
<textarea id="jsxOutput" placeholder="Output"></textarea>
</div>

<!-- JSON TOOL -->
<div id="json" class="tool">
<h3>JSON Formatter</h3>
<textarea id="jsonInput"></textarea>
<button onclick="formatJSON()">Format</button>
<textarea id="jsonOutput"></textarea>
</div>

<!-- BASE64 -->
<div id="base64" class="tool">
<h3>Base64 Encoder/Decoder</h3>
<textarea id="baseInput"></textarea>
<button onclick="encodeBase64()">Encode</button>
<button onclick="decodeBase64()">Decode</button>
<textarea id="baseOutput"></textarea>
</div>

<!-- FORMATTER -->
<div id="format" class="tool">
<h3>Code Formatter (Basic)</h3>
<textarea id="codeInput"></textarea>
<button onclick="formatCode()">Format</button>
<textarea id="codeOutput"></textarea>
</div>

</div>

<button onclick="toggleMode()" style="width:100%">Toggle Dark/Light</button>

<footer>
Made by Your Name
</footer>

<script>
function openTool(id) {
  document.querySelectorAll('.tool').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  event.target.classList.add('active');
}

// JSX converter (basic)
function convertJSX() {
  let input = document.getElementById("jsxInput").value;
  let output = input
    .replace(/class=/g, "className=")
    .replace(/for=/g, "htmlFor=");
  document.getElementById("jsxOutput").value = output;
}

// JSON formatter
function formatJSON() {
  try {
    let input = document.getElementById("jsonInput").value;
    let formatted = JSON.stringify(JSON.parse(input), null, 2);
    document.getElementById("jsonOutput").value = formatted;
  } catch {
    alert("Invalid JSON");
  }
}

// Base64
function encodeBase64() {
  let input = document.getElementById("baseInput").value;
  document.getElementById("baseOutput").value = btoa(input);
}

function decodeBase64() {
  let input = document.getElementById("baseInput").value;
  document.getElementById("baseOutput").value = atob(input);
}

// Code formatter (basic indent)
function formatCode() {
  let code = document.getElementById("codeInput").value;
  document.getElementById("codeOutput").value = code
    .replace(/{/g, "{\n")
    .replace(/}/g, "\n}")
    .replace(/;/g, ";\n");
}

// Copy
function copyOutput(id) {
  let text = document.getElementById(id);
  text.select();
  document.execCommand("copy");
}

// Clear
function clearFields(i, o) {
  document.getElementById(i).value = "";
  document.getElementById(o).value = "";
}

// Theme toggle
function toggleMode() {
  document.body.classList.toggle("light");
}
</script>

</body>
</html>
